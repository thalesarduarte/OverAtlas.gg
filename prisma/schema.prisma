generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FavoriteType {
  TEAM
  PLAYER
  TOURNAMENT
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  password      String?
  image         String?
  createdAt     DateTime        @default(now())
  accounts      Account[]
  sessions      Session[]
  favorites     Favorite[]
  linkedProfile LinkedProfile?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Team {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  shortName   String?
  logoUrl     String?
  region      String?
  description String?
  players     Player[]
}

model Player {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  realName    String?
  region      String?
  role        String?
  photoUrl    String?
  description String?
  teamId      String?
  team        Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
}

model Tournament {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  stage       String?
  location    String?
  startDate   DateTime?
  endDate     DateTime?
  prizePool   String?
  description String?
}

model Favorite {
  id        String       @id @default(cuid())
  userId    String
  type      FavoriteType
  refId     String
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, refId])
  @@index([userId, createdAt])
}

model LinkedProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  battleTag   String   @unique
  region      String?
  platform    String?
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CachedProfile {
  id            String       @id @default(cuid())
  battleTag     String       @unique
  playerName    String
  avatarUrl     String?
  title         String?
  region        String?
  roleSummary   String?
  overallWinrate Float?
  totalHours    Float?
  rankSummary   String?
  updatedAt     DateTime     @updatedAt
  heroStats     CachedHeroStat[]
}

model CachedHeroStat {
  id              String        @id @default(cuid())
  profileId       String
  heroName        String
  role            String
  winrate         Float
  hoursPlayed     Float
  eliminationsAvg Float?
  deathsAvg       Float?
  damageAvg       Float?
  profile         CachedProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}
